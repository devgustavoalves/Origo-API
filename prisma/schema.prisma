generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String   @unique
  senha_hash  String
  plano_saas  String   @default("free")
  createdAt   DateTime @default(now())

  @@map("usuarios")
}